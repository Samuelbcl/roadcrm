# Google OAuth (from Google Cloud Console)
GOOGLE_CLIENT_ID=ton-client-id-ici.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=ton-client-secret-ici

# Microsoft Azure AD (from Azure Portal → App registrations)
AZURE_AD_CLIENT_ID=ton-client-id-azure
AZURE_AD_CLIENT_SECRET=ton-client-secret-azure
AZURE_AD_TENANT_ID=common

# NextAuth
NEXTAUTH_SECRET=genere-un-secret-random-ici
NEXTAUTH_URL=http://localhost:3000

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://ton-projet.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=ta-cle-anon-ici
